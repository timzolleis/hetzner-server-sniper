# The values you must provide.
#
# - "Deploy to Cloudflare" button: you are prompted for each and they are stored
#   as Worker secrets. Leave a channel's fields blank to disable that channel.
# - Local dev: copy this file to `.dev.vars` and fill it in.
# - Manual deploy: set each with `wrangler secret put <NAME>`.

# ── Required ──
# Hetzner Cloud API token (a read-only token is sufficient).
HETZNER_API_TOKEN="your-hetzner-cloud-api-token"
# A long random secret. Callers send it as `Authorization: Bearer <token>`.
API_BEARER_TOKEN="a-long-random-shared-secret"

# ── Notifications: configure AT LEAST ONE channel (both is fine) ──

# E-mail via Resend — set all three together, or leave all blank.
RESEND_API_KEY="re_..."
NOTIFICATION_EMAIL="you@example.com"          # default recipient
RESEND_FROM_EMAIL="sniper@your-verified-domain.com"  # must be Resend-verified

# Generic webhook — POSTs a JSON payload to this URL.
WEBHOOK_URL="https://example.com/your-webhook"
# Optional: signs each body with `X-Sniper-Signature: sha256=<hmac>`.
# WEBHOOK_SECRET="a-shared-signing-secret"

# ── Optional overrides — defaults live in wrangler.jsonc ──
# POLL_INTERVAL_SECONDS="30"
# REQUEST_TTL_DAYS="30"
# SERVER_TYPE_CACHE_TTL_SECONDS="3600"
# HETZNER_RATE_LIMIT_PER_HOUR="3600"
